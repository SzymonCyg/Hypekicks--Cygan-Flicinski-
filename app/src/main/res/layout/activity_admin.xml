<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widokGlownyAdmin"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".AdminActivity">

    <ImageView
        android:id="@+id/przyciskZamknijAdmin"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="end"
        android:layout_margin="8dp"
        android:src="@drawable/baseline_close_24"
        android:padding="12dp"
        app:tint="@color/black" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:text="Panel Administratora"
        android:textSize="24sp"
        android:textStyle="bold|italic" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dodaj nowe buty"
                android:textSize="18sp"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etMarka"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Marka"
                android:inputType="textCapWords" />

            <EditText
                android:id="@+id/etModel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Model"
                android:inputType="textCapWords" />

            <EditText
                android:id="@+id/etCena"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Cena"
                android:inputType="numberDecimal" />

            <EditText
                android:id="@+id/etRok"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Rok wydania"
                android:inputType="number" />

            <EditText
                android:id="@+id/etUrlZdjecia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="URL zdjęcia"
                android:inputType="textUri" />

            <Button
                android:id="@+id/btnDodajButy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Dodaj Buty" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCCCCC"
                android:layout_marginVertical="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Zarządzaj listą"
                android:textSize="18sp"
                android:layout_marginBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvListaButowAdmin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
